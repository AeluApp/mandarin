{
  "productName": "Aelu",
  "identifier": "com.aelu.desktop",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "漫 Aelu",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 500,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Aelu uses your microphone for speaking practice and tone grading."
      }
    },
    "externalBin": [
      "binaries/mandarin-server"
    ]
  }
}
