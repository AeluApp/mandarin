# Required in production
SECRET_KEY=change-me-to-a-random-string
IS_PRODUCTION=true
BASE_URL=https://your-domain.com

# Stripe (payment processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (error monitoring)
SENTRY_DSN=https://...@sentry.io/...

# Resend (transactional email)
RESEND_API_KEY=re_...
FROM_EMAIL=Mandarin <noreply@yourdomain.com>

# Database (defaults to ./data/mandarin.db)
# DATA_DIR=/data

# Litestream replication (optional)
# LITESTREAM_REPLICA_URL=s3://bucket/path
# LITESTREAM_S3_BUCKET=your-bucket
# LITESTREAM_S3_PATH=mandarin
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Analytics (Plausible)
PLAUSIBLE_DOMAIN=aeluapp.com
PLAUSIBLE_API_KEY=
# PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# JWT (mobile auth)
# JWT_SECRET=change-me-to-a-random-string
# JWT_ACCESS_EXPIRY_HOURS=1
# JWT_REFRESH_EXPIRY_DAYS=30

# Push notifications (VAPID)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=mailto:admin@aeluapp.com

# Session timeout (minutes)
# SESSION_TIMEOUT_MINUTES=30

# Security alerts
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...
ADMIN_EMAIL=admin@yourdomain.com

# Flask environment (controls JSON log format in production)
# FLASK_ENV=production

# Server
# PORT=8080
