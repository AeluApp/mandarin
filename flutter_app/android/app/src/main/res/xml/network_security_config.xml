<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration — Android

  OWASP M3 (Insecure Communication):
  - Block all cleartext (HTTP) traffic in production.
  - Allow localhost for debug builds only.

  NIST SC-8 (Transmission Confidentiality):
  - Enforce TLS for all network communication.

  CIS Mobile 6.1 (Network Communication):
  - Certificate pinning via pin-set.
  - Expiration date triggers re-pinning review.
-->
<network-security-config>
    <!-- Block cleartext traffic globally. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Production API domain — certificate pinning. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">aeluapp.com</domain>
        <pin-set expiration="2027-01-01">
            <!--
              BEFORE APP STORE RELEASE: Replace pin-set digests below with actual
              SHA-256 SPKI hashes from the production certificate chain.

              To generate the primary pin (leaf certificate):
                openssl s_client -servername aeluapp.com -connect aeluapp.com:443 \
                  </dev/null 2>/dev/null | \
                  openssl x509 -pubkey -noout | \
                  openssl pkey -pubin -outform DER | \
                  openssl dgst -sha256 -binary | \
                  openssl enc -base64

              To generate the backup pin (intermediate/root CA certificate):
                openssl s_client -servername aeluapp.com -connect aeluapp.com:443 \
                  -showcerts </dev/null 2>/dev/null | \
                  openssl x509 -pubkey -noout | \
                  openssl pkey -pubin -outform DER | \
                  openssl dgst -sha256 -binary | \
                  openssl enc -base64

              You need at least 2 pins: the primary (leaf) cert and a backup
              (intermediate CA or a separately issued backup cert) so the app
              continues to work during certificate rotation.

              Until real hashes are added, certificate pinning will not be
              enforced (the placeholder values will never match).
            -->
            <pin digest="SHA-256">CONFIGURE_BEFORE_RELEASE=</pin>
            <!-- Backup pin (intermediate CA or backup cert for rotation). -->
            <pin digest="SHA-256">CONFIGURE_BEFORE_RELEASE_BACKUP=</pin>
        </pin-set>
    </domain-config>

    <!-- Debug: allow cleartext to localhost for development. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
