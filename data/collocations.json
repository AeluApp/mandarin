  "entries": [
    {"verb": "打", "object": "电话", "meaning": "make a phone call", "literal": "hit phone", "hsk_level": 1, "confusables": ["说", "做", "叫"], "example": "老周说他会打电话给你。等了两天。方阿姨说：他忘了。"},
    {"verb": "打", "object": "篮球", "meaning": "play basketball", "literal": "hit basketball", "hsk_level": 2, "confusables": ["玩", "做", "踢"], "example": "他喜欢打篮球。"},
    {"verb": "踢", "object": "足球", "meaning": "play soccer", "literal": "kick football", "hsk_level": 2, "confusables": ["打", "玩", "做"], "example": "我们一起踢足球吧。"},
    {"verb": "看", "object": "病", "meaning": "see a doctor", "literal": "look at illness", "hsk_level": 2, "confusables": ["去", "做", "治"], "example": "你应该去看病。"},
