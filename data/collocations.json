    {"verb": "唱", "object": "歌", "meaning": "sing a song", "literal": "sing song", "hsk_level": 1, "confusables": ["说", "做", "听"], "example": "她唱歌唱得很好。"},
    {"verb": "跑", "object": "步", "meaning": "go jogging", "literal": "run steps", "hsk_level": 2, "confusables": ["做", "走", "运"], "example": "老周说他要每天跑步。第一天跑了，第二天没跑。小梅说：意料之中。"},
    {"verb": "见", "object": "面", "meaning": "meet (in person)", "literal": "see face", "hsk_level": 2, "confusables": ["看", "做", "遇"], "example": "我们明天见面吧。"},
    {"verb": "发", "object": "烧", "meaning": "have a fever", "literal": "emit burn", "hsk_level": 3, "confusables": ["做", "有", "得"], "example": "孩子发烧了。"},
    {"verb": "请", "object": "客", "meaning": "treat someone (to a meal)", "literal": "invite guest", "hsk_level": 3, "confusables": ["做", "吃", "给"], "example": "老周说今天他请客。大家都来了。吃完饭老周才发现没带钱包。方阿姨付了钱。"},
    {"verb": "开", "object": "玩笑", "meaning": "joke around", "literal": "open joke", "hsk_level": 3, "confusables": ["说", "做", "讲"], "example": "老白喜欢开玩笑。但是大家常常不确定他是不是在开玩笑。老白也不确定。"},
    {"verb": "散", "object": "步", "meaning": "take a walk", "literal": "scatter steps", "hsk_level": 3, "confusables": ["走", "做", "跑"], "example": "我们去散步吧。"},
    {"verb": "排", "object": "队", "meaning": "stand in line", "literal": "arrange line", "hsk_level": 3, "confusables": ["站", "做", "等"], "example": "请排队等候。"},
    {"verb": "吵", "object": "架", "meaning": "quarrel", "literal": "noisy fight", "hsk_level": 3, "confusables": ["打", "做", "说"], "example": "方阿姨说了一句，老周不同意，两个人又吵架了。小梅看了看手表。"},
    {"verb": "打", "object": "折", "meaning": "give a discount", "literal": "hit fold", "hsk_level": 3, "confusables": ["做", "给", "减"], "example": "这件衣服打八折。"},
