    {"verb": "洗", "object": "澡", "meaning": "take a bath/shower", "literal": "wash bath", "hsk_level": 2, "confusables": ["做", "冲", "泡"], "example": "我先洗澡。"},
    {"verb": "刮", "object": "风", "meaning": "wind blows", "literal": "scrape wind", "hsk_level": 3, "confusables": ["下", "吹", "来"], "example": "外面刮风了。"},
    {"verb": "担", "object": "心", "meaning": "worry", "literal": "carry heart", "hsk_level": 3, "confusables": ["做", "有", "想"], "example": "罗老师说情况很严重。秦经理说别担心，有规定。罗老师说：规定解决不了这个！"},
    {"verb": "上", "object": "网", "meaning": "go online", "literal": "go up net", "hsk_level": 2, "confusables": ["做", "用", "玩"], "example": "他每天上网。"},
    {"verb": "打", "object": "工", "meaning": "work a part-time job", "literal": "hit work", "hsk_level": 3, "confusables": ["做", "去", "干"], "example": "大学生暑假打工。"},
    {"verb": "请", "object": "假", "meaning": "ask for leave", "literal": "request fake/leave", "hsk_level": 3, "confusables": ["做", "要", "休"], "example": "老周想请假去参加比赛。秦经理说要填表。老周填了三张表。秦经理说还差一张。"},
    {"verb": "理", "object": "发", "meaning": "get a haircut", "literal": "manage hair", "hsk_level": 3, "confusables": ["做", "剪", "切"], "example": "我该去理发了。"},
    {"verb": "握", "object": "手", "meaning": "shake hands", "literal": "grasp hand", "hsk_level": 3, "confusables": ["做", "拉", "打"], "example": "他们握手了。"},
    {"verb": "发", "object": "脾气", "meaning": "lose one's temper", "literal": "emit temper", "hsk_level": 4, "confusables": ["做", "生", "有"], "example": "罗老师经常发脾气，但是发完以后马上又笑了。小梅说：她发脾气跟天气预报一样，准时但是不持久。"},
    {"verb": "动", "object": "手术", "meaning": "have surgery", "literal": "move surgery", "hsk_level": 4, "confusables": ["做", "开", "打"], "example": "他明天动手术。"},
    {"verb": "占", "object": "便宜", "meaning": "take advantage of", "literal": "occupy cheap", "hsk_level": 4, "confusables": ["做", "拿", "得"], "example": "老周以为打折的时候多买就是占便宜。方阿姨说：你买了十双袜子，你只有两只脚。"},
    {"verb": "吃", "object": "苦", "meaning": "endure hardship", "literal": "eat bitterness", "hsk_level": 4, "confusables": ["做", "受", "有"], "example": "老白说年轻人不怕吃苦。方阿姨问：你年轻的时候吃过什么苦？老白想了很久，说：我想不起来了。"},
    {"verb": "丢", "object": "脸", "meaning": "lose face", "literal": "lose face", "hsk_level": 4, "confusables": ["做", "没", "掉"], "example": "老周在客户面前唱了一首歌。罗老师小声说：丢脸。老周说：他们鼓掌了。小梅说：那是礼貌。"},
    {"verb": "伤", "object": "心", "meaning": "be heartbroken", "literal": "wound heart", "hsk_level": 3, "confusables": ["做", "难", "疼"], "example": "小梅的猫走丢了。她没说什么，但是三天没吃零食。方阿姨知道她很伤心。"},
    {"verb": "出", "object": "差", "meaning": "go on a business trip", "literal": "exit errand", "hsk_level": 3, "confusables": ["做", "去", "走"], "example": "他下周出差。"},
    {"verb": "转", "object": "弯", "meaning": "make a turn", "literal": "turn curve", "hsk_level": 3, "confusables": ["做", "走", "拐"], "example": "前面转弯。"},
    {"verb": "着", "object": "急", "meaning": "be anxious", "literal": "touch anxious", "hsk_level": 3, "confusables": ["做", "有", "想"], "example": "别着急。"},
    {"verb": "放", "object": "心", "meaning": "rest assured", "literal": "put down heart", "hsk_level": 3, "confusables": ["做", "安", "别"], "example": "秦经理说：你放心，手续我来办。他说这句话的时候，你确实放心了。不是因为手续，是因为他说话的语气。"},
    {"verb": "打", "object": "针", "meaning": "get an injection", "literal": "hit needle", "hsk_level": 3, "confusables": ["做", "给", "扎"], "example": "小孩怕打针。"}
  ]
