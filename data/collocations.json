    {"verb": "生", "object": "气", "meaning": "get angry", "literal": "generate qi/air", "hsk_level": 2, "confusables": ["做", "有", "来"], "example": "方阿姨又说了实话。老周生气了。小梅说：她每次都这样，你每次都生气。"},
    {"verb": "睡", "object": "觉", "meaning": "sleep", "literal": "sleep sense", "hsk_level": 1, "confusables": ["做", "休", "躺"], "example": "我想睡觉了。"},
