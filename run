#!/usr/bin/env bash
# 漫 Mandarin — Patient Mandarin study. Honest data, no theatrics.
# Usage: ./run [command]
#   ./run          → today's session
#   ./run menu     → interactive menu
#   ./run mini     → 90-second session
#   ./run status   → learning status
#   ./run forecast → projections
#   ./run report   → progress report
#   ./run help     → all commands

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$SCRIPT_DIR/venv"

# Check Python
if ! command -v python3 &>/dev/null; then
    echo ""
    echo "  Python 3 is not installed."
    echo ""
    echo "  To install on macOS:"
    echo "    brew install python3"
    echo ""
    echo "  Then run this script again."
    exit 1
fi

# Check/create venv
if [ ! -d "$VENV" ]; then
    echo "  Setting up environment (first run only)..."
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet -e "$SCRIPT_DIR"
    echo "  Done. Starting system."
    echo ""
fi

# Activate venv
source "$VENV/bin/activate"

# Check package is installed
if ! python3 -c "import mandarin" 2>/dev/null; then
    echo "  Installing mandarin package..."
    pip install --quiet -e "$SCRIPT_DIR"
fi

CMD="${1:-}"

case "$CMD" in
    menu)
        python3 -m mandarin.menu
        ;;
    doctor)
        python3 -m mandarin.doctor
        ;;
    churn-report)
        shift
        python3 -m mandarin.churn_detection "$@"
        ;;
    metrics)
        shift
        python3 -m mandarin.metrics_report "$@"
        ;;
    test)
        echo "  Running tests..."
        for f in tests/test_*.py; do
            python3 "$f"
        done
        ;;
    test-coverage)
        echo "  Running tests with coverage..."
        python3 -m coverage erase
        for f in tests/test_*.py; do
            python3 -m coverage run --append "$f"
        done
        python3 -m coverage report
        echo ""
        echo "  For HTML report: python3 -m coverage html && open htmlcov/index.html"
        ;;
    help|--help|-h)
        echo ""
        echo "  漫 Mandarin"
        echo ""
        echo "  Usage: ./run [command]"
        echo ""
        echo "  Session commands:"
        echo "    (no args)    Run today's session"
        echo "    mini         90-second minimal session"
        echo "    catchup      Catch-up session (weak spots)"
        echo "    speak        Speaking practice (voice tone grading)"
        echo "    calibrate    Calibration session"
        echo ""
        echo "  Menu:"
        echo "    menu         Interactive menu (no typing commands)"
        echo ""
        echo "  Media:"
        echo "    watch        Recommend real Chinese media + quiz"
        echo "    watch --list Show media catalog"
        echo ""
        echo "  Info commands:"
        echo "    portfolio    Your mastered vocabulary wall"
        echo "    status       Current learning status (alias: memory)"
        echo "    forecast     Learning projections"
        echo "    report       Full progress report"
        echo "    history      Recent session history (alias: sessions)"
        echo "    errors       Recent error details"
        echo "    scenarios    List dialogue scenarios"
        echo ""
        echo "  Content commands:"
        echo "    add-hsk <n>  Load HSK level vocabulary (1-9)"
        echo "    sync-hsk     Load all HSK levels at once"
        echo "    seed-grammar Load grammar points and skills"
        echo "    library      Show content library"
        echo "    grammar      Show grammar points"
        echo "    skills       Show language skills"
        echo ""
        echo "  Web:"
        echo "    app          Launch web interface in browser"
        echo ""
        echo "  Analytics:"
        echo "    churn-report Churn detection and risk scoring"
        echo "    metrics      Weekly metrics report with KPIs"
        echo ""
        echo "  System:"
        echo "    assess       Diagnostic assessment"
        echo "    improve      Self-improvement proposals"
        echo "    focus <lens> Boost a content lens"
        echo "    settings     View/change settings"
        echo "    doctor       System health check"
        echo "    seed-context Load context notes"
        echo "    retention-purge  Purge expired data per retention policies"
        echo "    test         Run tests"
        echo "    test-coverage Run tests with coverage report"
        echo "    help         This help message"
        echo ""
        echo "  Shell integration:"
        echo "    source ~/mandarin/shell-hook.sh  (add to .zshrc)"
        echo ""
        ;;
    "")
        python3 -m mandarin.cli
        ;;
    *)
        python3 -m mandarin.cli "$@"
        ;;
esac
